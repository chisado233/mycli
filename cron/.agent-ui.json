{
  "id": "mycli.cron.ui",
  "name": "Cron Scheduler UI",
  "description": "Monitor mycli cron tasks, scheduler state, recent runs, and run/enable/disable tasks.",
  "type": "mycli-ui",
  "url": "http://127.0.0.1:46010",
  "health": { "url": "http://127.0.0.1:46010/api/snapshot", "timeoutMs": 3000 },
  "commands": {
    "start": ["cron", "ui"],
    "stop": ["cron", "ui-stop"],
    "open": ["cron", "ui-open"]
  }
}
