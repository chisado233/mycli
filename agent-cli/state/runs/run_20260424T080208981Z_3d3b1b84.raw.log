}\")\n+            lines.append(\"\")\n+    else:\n+        lines.append(\"- No phase-specific dynamic context recorded yet.\")\n+    return \"\\n\".join(lines) + \"\\n\"\n+\n+\n+def cmd_agent_guide(args: argparse.Namespace) -> int:\n+    project_file = resolve_project_file(args, args.key)\n+    project = read_json(project_file)\n+    print(render_agent_guide(project, project_file, args.phase))\n+    return 0\n+\n+\n+def cmd_maintenance_guide(args: argparse.Namespace) -> int:\n+    project_file = resolve_project_file(args, args.key)\n+    project = read_json(project_file)\n+    operations = project.get(\"operations\") if isinstance(project.get(\"operations\"), dict) else None\n+    print(render_agent_guide(project, project_file, \"maintenance\"))\n+    print(\"\\n# Operations / Maintenance Snapshot\\n\")\n+    if operations:\n+        for key in [\"enabled\", \"cadence\", \"trigger\", \"schedule_expr\", \"last_run_at\", \"last_run_status\", \"last_success_at\", \"next_run_at\", \"consecutive_failures\", \"runbook\"]:\n+            print(f\"- {key}: {operations.get(key)}\")\n+    else:\n+        print(\"- Operations not configured for this project.\")\n+    return 0\n+\n+\n def build_parser() -> argparse.ArgumentParser:\n     parser = argparse.ArgumentParser(prog=\"project-manager\", description=\"Manage durable agent projects\")\n     parser.add_argument(\"--registry\", help=\"Registry path override\")\n     sub = parser.add_subparsers(dest=\"command\", required=True)\n@@ -972,8 +1204,51 @@\n     next_update.add_argument(\"--due-at\")\n     next_update.add_argument(\"--set-current\", action=\"store_true\")\n     next_update.set_defaults(func=cmd_next_update)\n \n+    context_add = sub.add_parser(\"context-add\", help=\"Add dynamic project context for a phase\")\n+    context_add.add_argument(\"key\")\n+    context_add.add_argument(\"--id\")\n+    context_add.add_argument(\"--title\", required=True)\n+    context_add.add_argument(\"--phase\", default=\"all\")\n+    context_add.add_argument(\"--type\", default=\"note\")\n+    context_add.add_argument(\"--status\", default=\"active\")\n+    context_add.add_argument(\"--priority\", default=\"medium\")\n+    context_add.add_argument(\"--summary\")\n+    context_add.add_argument(\"--content\")\n+    context_add.add_argument(\"--file\", action=\"append\")\n+    context_add.add_argument(\"--tag\", action=\"append\")\n+    context_add.add_argument(\"--source\")\n+    context_add.set_defaults(func=cmd_context_add)\n+\n+    context_list = sub.add_parser(\"context-list\", help=\"List dynamic project context entries\")\n+    context_list.add_argument(\"key\")\n+    context_list.add_argument(\"--phase\")\n+    context_list.add_argument(\"--type\")\n+    context_list.add_argument(\"--status\")\n+    context_list.add_argument(\"--json\", action=\"store_true\")\n+    context_list.set_defaults(func=cmd_context_list)\n+\n+    context_get = sub.add_parser(\"context-get\", help=\"Read one dynamic context entry\")\n+    context_get.add_argument(\"key\")\n+    context_get.add_argument(\"context_id\")\n+    context_get.add_argument(\"--json\", action=\"store_true\")\n+    context_get.set_defaults(func=cmd_context_get)\n+\n+    current = sub.add_parser(\"current\", help=\"Show current project status, current task, and current next action\")\n+    current.add_argument(\"key\")\n+    current.add_argument(\"--json\", action=\"store_true\")\n+    current.set_defaults(func=cmd_current)\n+\n+    agent_guide = sub.add_parser(\"agent-guide\", help=\"Print project management guide and project context for agent handoff\")\n+    agent_guide.add_argument(\"key\")\n+    agent_guide.add_argument(\"--phase\")\n+    agent_guide.set_defaults(func=cmd_agent_guide)\n+\n+    maintenance_guide = sub.add_parser(\"maintenance-guide\", help=\"Print maintenance and operations guide for a project\")\n+    maintenance_guide.add_argument(\"key\")\n+    maintenance_guide.set_defaults(func=cmd_maintenance_guide)\n+\n     return pa