"- {item}\")\n+    return 0\n+\n+\n+def read_open_records(project_file: Path, folder: str, prefix: str, open_statuses: set[str]) -> list[dict[str, Any]]:\n+    records = load_records(project_file.parent / folder, prefix)\n+    return [r for r in records if r.get(\"status\") in open_statuses]\n+\n+\n+def cmd_current(args: argparse.Namespace) -> int:\n+    project_file = resolve_project_file(args, args.key)\n+    project = read_json(project_file)\n+    current = project.get(\"current\", {})\n+    task_id = current.get(\"task_id\")\n+    next_id_value = current.get(\"next_action_id\")\n+    result: dict[str, Any] = {\"project\": project.get(\"metadata\", {}), \"status\": project.get(\"status\", {}), \"current\": current}\n+    if task_id:\n+        task_path = project_file.parent / \"tasks\" / f\"{task_id}.json\"\n+        if task_path.exists():\n+            result[\"current_task\"] = read_json(task_path)\n+    if next_id_value:\n+        next_path = project_file.parent / \"next-actions\" / f\"{next_id_value}.json\"\n+        if next_path.exists():\n+            result[\"current_next_action\"] = read_json(next_path)\n+    if args.json:\n+        print(json.dumps(result, ensure_ascii=False, indent=2))\n+    else:\n+        meta = result[\"project\"]\n+        status = result[\"status\"]\n+        print(f\"# Current Project: {meta.get('name')} ({meta.get('id')})\\n\")\n+        print(f\"- Lifecycle: {status.get('lifecycle')}\")\n+        print(f\"- Phase: {status.get('phase')}\")\n+        print(f\"- Activity: {status.get('activity')}\")\n+        print(f\"- Health: {status.get('health')}\")\n+        print(f\"- Delivery: {status.get('delivery')}\")\n+        print(f\"- Attention: {', '.join(status.get('attention') or []) or 'none'}\\n\")\n+        print(\"## Current Focus\\n\")\n+        print(current.get(\"summary\", \"\"), \"\\n\")\n+        if \"current_task\" in result:\n+            task = result[\"current_task\"]\n+            print(\"## Current Task\\n\")\n+            print(f\"- {task.get('id')}: {task.get('title')} [{task.get('status')}]\\n\")\n+        if \"current_next_action\" in result:\n+            action = result[\"current_next_action\"]\n+            print(\"## Current Next Action\\n\")\n+            print(f\"- {action.get('id')}: {action.get('title')} [{action.get('status')}]\\n\")\n+    return 0\n+\n+\n+def render_agent_guide(project: dict[str, Any], project_file: Path, phase: str | None = None) -> str:\n+    meta = project.get(\"metadata\", {})\n+    spec = project.get(\"spec\", {})\n+    status = project.get(\"status\", {})\n+    current = project.get(\"current\", {})\n+    phase = phase or status.get(\"phase\")\n+    context_records = load_records(context_entries_dir(project_file), \"context\")\n+    relevant_context = [r for r in context_records if not phase or r.get(\"phase\") in {phase, \"all\", None, \"\"}]\n+    open_tasks = read_open_records(project_file, \"tasks\", \"task\", {\"proposed\", \"accepted\", \"ready\", \"in_progress\", \"blocked\", \"review\"})\n+    open_next = read_open_records(project_file, \"next-actions\", \"next\", {\"open\", \"active\", \"waiting\"})\n+    lines = [\n+        f\"# Agent Handoff Guide: {meta.get('name')} ({meta.get('id')})\",\n+        \"\",\n+        \"## Project Identity\",\n+        \"\",\n+        f\"- Root: {meta.get('root')}\",\n+        f\"- Type: {spec.get('project_type')}\",\n+        f\"- Mode: {spec.get('project_mode')}\",\n+        f\"- Owner: {meta.get('owner')}\",\n+        f\"- Domain: {meta.get('domain')}\",\n+        f\"- Tags: {', '.join(meta.get('tags') or [])}\",\n+        \"\",\n+        \"## Current Status\",\n+        \"\",\n+        f\"- Lifecycle: {status.get('lifecycle')}\",\n+        f\"- Phase: {status.get('phase')}\",\n+        f\"- Activity: {status.get('activity')}\",\n+        f\"- Health: {status.get('health')}\",\n+        f\"- Delivery: {status.get('delivery')}\",\n+        f\"- Attention: {', '.join(status.get('attention') or []) o