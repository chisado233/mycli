hes($text, '(?m)^#\\s+(.+)$')) {\n+        $name = $m.Groups[1].Value.Trim()\n+        if ($name -notmatch '连续性备注|全书收束备注|供整合者检查事项|已解决的核心冲突|主要人物结局收束|保留的非关键余味') {\n+            $result.Add($name)\n+        }\n+    }\n+    return $result\n+}\n+\n+$chapters = New-Object System.Collections.Generic.List[string]\n+foreach ($p in @($part1, $part2, $part3)) {\n+    foreach ($c in (Get-Chapters $p)) { $chapters.Add($c) }\n+}\n+\n+$clean1 = $part1 -replace '(?s)\\r?\\n---\\r?\\n\\r?\\n## 本批连续性备注[\\s\\S]*$',''\n+$clean2 = $part2 -replace '(?s)\\r?\\n---\\r?\\n\\r?\\n## 连续性备注[\\s\\S]*$',''\n+$clean3 = $part3 -replace '(?s)\\r?\\n---\\r?\\n\\r?\\n## 全书收束备注[\\s\\S]*$',''\n+\n+$novelLines = New-Object System.Collections.Generic.List[string]\n+$null = $novelLines.Add(\"# 《$title》\")\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('## 简介')\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add($intro)\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('## 世界观设定')\n+$null = $novelLines.Add('')\n+foreach ($line in $world) { $null = $novelLines.Add($line) }\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('## 主要人物')\n+$null = $novelLines.Add('')\n+foreach ($key in $characters.Keys) { $null = $novelLines.Add(\"- **$key**：$($characters[$key])\") }\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('## 章节目录')\n+$null = $novelLines.Add('')\n+for ($i = 0; $i -lt $chapters.Count; $i++) { $null = $novelLines.Add(\"$($i + 1). $($chapters[$i])\") }\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('---')\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add($clean1.Trim())\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add($clean2.Trim())\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add($clean3.Trim())\n+\n+$novelPath = Join-Path $base 'novel.md'\n+[System.IO.File]::WriteAllText($novelPath, ($novelLines -join [Environment]::NewLine), [System.Text.UTF8Encoding]::new($false))\n+\n+$bodyText = $clean1 + $clean2 + $clean3\n+$novelBodyCount = ([regex]::Matches($bodyText, '\\p{IsCJKUnifiedIdeographs}')).Count\n+\n+$readmeLines = New-Object System.Collections.Generic.List[string]\n+$null = $readmeLines.Add(\"# 《$title》\")\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add('## 书名')\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add(\"- 《$title》\")\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add('## 总字数估算')\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add(\"- 正文估算字数：约 $novelBodyCount 个中文字符\")\n+if ($novelBodyCount -ge 45000 -and $novelBodyCount -le 55000) {\n+    $null = $readmeLines.Add('- 结果判断：已达到父任务要求的 45,000-55,000 中文字合理目标区间')\n+} elseif ($novelBodyCount -ge 40000) {\n+    $null = $readmeLines.Add('- 结果判断：达到 40,000 字以上，但未落在 45,000-55,000 理想区间，应在上级验收时注明')\n+} else {\n+    $null = $readmeLines.Add('- 结果判断：低于 40,000 中文字，不满足父任务目标')\n+}\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add('## 章节列表')\n+$null = $readmeLines.Add('')\n+foreach ($chapter in $chapters) { $null = $readmeLines.Add(\"- $chapter\") }\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add('## 世界观与主线概述')\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add('- 世界以“烬潮”与“炼骨载潮”为修行底层规则，所谓修行盛世实则建立在众生细骨火被长期抽取之上。')\n+$null = $readmeLines.Add('- 主线围绕沈烬追查父母之死、揭开边荒祭骨制度与三宗续界真相、进入白阙天仓并与祁天陵进行价值对决展开。')\n+$null = $readmeLines.Add('- 结局并未粗暴毁阵，而是将旧续界主阵改写为“新潮共阙”体系：停止强制抽取凡民骨火，改由修士与各域公开共担承灾代价。')\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add('## 产物路径')\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add(\"- 小说正文：`$base\\\\novel.md`\")\n+$null = $readmeLines.Add(\"- 创作规划：`$base\\\\planning.md`\")\n+$null = $readmeLines.Add(\"- 分批草稿：`$base\\\\drafts\\\\part-01.md`、`$base\\\\drafts\\\\part-02.md`、`$base\\\\drafts\\\\part-03.md`\")\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add('## 自检结果')\n+$null = $readmeLines.Add('')\n+$null = $readmeLines.Add('- 已整合 22 章完整正文，保留章节标题。')\n+$null = $readmeLines.Add('- 已移除分批连续性备注、全书收束备注、供整合者检查事项等不应进入正文的整合说明。')\n+$null = $readmeLines.Add('- novel.md 前部已补齐书名、简介、世界观设定、主要人物设定、章节目录。')\n+$null = $readmeLines.Add('- 主线具备开端、发展、高潮、结局，核心冲突已解决，并保留归墟裂海的后续远景。')\n+$null = $readmeLines.Add(\"- 正文总字数估算约 $novelBodyCount 个中文字符。\")\n+\n+$readmePath = Join-Path $base 'README.md'\n+[System.IO.File]::WriteAllText($readmePath, ($readmeLines -join [Environment]::NewLine), [System.Text.UTF8Encoding]::new($false))\n","additions":127,"deletions":0}],"diagnostics":{},"truncated":false},"title":"Success. Updated the following files:\nA agent_workspace/tmp/task_20260427_223315_cae52b-build-novel.ps1","time":{"start":1777301901391,"end":1777301901450}},"id":"prt_dcf721b8c001bt6kxcACXdtFfL","sessionID":"ses_2309dc86dffeuBd7fNq88a32FU","messageID":"msg_dcf71e8190014tULEfroRdFoVv"}}
