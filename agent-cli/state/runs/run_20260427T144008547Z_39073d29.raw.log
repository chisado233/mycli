+        }\n+    }\n+    return $result\n+}\n+\n+$chapters = New-Object System.Collections.Generic.List[string]\n+foreach ($p in @($part1, $part2, $part3)) {\n+    foreach ($c in (Get-Chapters $p)) { $chapters.Add($c) }\n+}\n+\n+$clean1 = $part1 -replace '(?s)\\r?\\n---\\r?\\n\\r?\\n## 本批连续性备注[\\s\\S]*$',''\n+$clean2 = $part2 -replace '(?s)\\r?\\n---\\r?\\n\\r?\\n## 连续性备注[\\s\\S]*$',''\n+$clean3 = $part3 -replace '(?s)\\r?\\n---\\r?\\n\\r?\\n## 全书收束备注[\\s\\S]*$',''\n+\n+$novelLines = New-Object System.Collections.Generic.List[string]\n+$null = $novelLines.Add(\"# 《$title》\")\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('## 简介')\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add($intro)\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('## 世界观设定')\n+$null = $novelLines.Add('')\n+foreach ($line in $world) { $null = $novelLines.Add($line) }\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('## 主要人物')\n+$null = $novelLines.Add('')\n+foreach ($key in $characters.Keys) { $null = $novelLines.Add(\"- **$key**：$($characters[$key])\") }\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('## 章节目录')\n+$null = $novelLines.Add('')\n+for ($i = 0; $i -lt $chapters.Count; $i++) { $null = $novelLines.Add(\"$($i + 1). $($chapters[$i])\") }\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add('---')\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add($clean1.Trim())\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add($clean2.Trim())\n+$null = $novelLines.Add('')\n+$null = $novelLines.Add($clean3.Trim())\n+\n+$novelPath = Join-Path $base 'novel.md'\n+[System.IO.File]::WriteAllText($novelPath, ($novelLines -join [Environment]::NewLine), [System.Text.UTF8Encoding]::new($false))\n+\n+$bodyText = $clean1 + $clean2 + $clean3\n+$novelBodyCount = ([regex]::Matches($bodyText, '\\p{IsCJKUnifiedIdeographs}')).Count\n+\n+$readmeLines = New-Object System.Collections.Generic.List[string]\n+$null = $readmeLines.Add(\"# 《$title》\")\n+$null = $readmeLines.Add