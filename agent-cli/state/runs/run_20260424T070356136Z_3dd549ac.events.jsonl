g)\n45:     } catch {\n46:         Write-SkillLibraryError \"Failed to write UTF-8 text to '$Path'. $($_.Exception.Message)\"\n47:     }\n48: }\n49: \n50: function Get-PackageConfigObject {\n51:     if (-not (Test-Path -LiteralPath $script:ConfigPath)) {\n52:         Write-SkillLibraryError \"Package config not found at '$script:ConfigPath'.\"\n53:     }\n54: \n55:     try {\n56:         return (Read-Utf8Text -Path $script:ConfigPath) | ConvertFrom-Json\n57:     } catch {\n58:         Write-SkillLibraryError \"Failed to parse package config. $($_.Exception.Message)\"\n59:     }\n60: }\n61: \n62: function Get-DefaultSourceRoot {\n63:     $config = Get-PackageConfigObject\n64:     if (-not $config.source) {\n65:         Write-SkillLibraryError \"Package config does not define a source path.\"\n66:     }\n67:     return [string]$config.source\n68: }\n69: \n70: function Ensure-RegistryFile {\n71:     if (-not (Test-Path -LiteralPath $script:RegistryPath)) {\n72:         Write-Utf8Text -Path $script:RegistryPath -Content \"[]`r`n\"\n73:     }\n74: }\n75: \n76: function Get-RegistryEntries {\n77:     Ensure-RegistryFile\n78: \n79:     try {\n80:         $data = (Read-Utf8Text -Path $script:RegistryPath) | ConvertFrom-Json\n81:     } catch {\n82:         Write-SkillLibraryError \"Failed to parse registry at '$script:RegistryPath'. $($_.Exception.Message)\"\n83:     }\n84: \n85:     if ($null -eq $data) {\n86:         return @()\n87:     }\n88: \n89:     if ($data -is [System.Array]) {\n90:         return @($data)\n91:     }\n92: \n93:     return @($data)\n94: }\n95: \n96: function Save-RegistryEntries {\n97:     param([object[]]$Entries)\n98: \n99:     $json = @($Entries) | Sort-Object name, skillMdPath | ConvertTo-Json -Depth 10\n100:     Write-Utf8Text -Path $script:RegistryPath -Content $json\n101: }\n102: \n103: function Get-FrontmatterValue {\n104:     param(\n105:         [string]$Frontmatter,\n106:         [string]$Name\n107:     )\n108: \n109:     if ([string]::IsNullOrWhiteSpace($Frontmatter)) {\n110:         return $null\n111:     }\n112: \n113:     $lines = @($Frontmatter -split \"\\r?\\n\")\n114:     for ($index = 0; $index -lt $lines.Count; $index++) {\n115:         $line = $lines[$index]\n116:         if ($line -notmatch \"^(?<indent>\\s*)$([regex]::Escape($Name)):\\s*(?<value>.*)$\") {\n117:             continue\n118:         }\n119: \n120:         $rawValue = $matches['value'].Trim()\n121:         if ($rawValue -in @('|', '>')) {\n122:             $baseIndent = $matches['indent'].Length\n123:             $collected = New-Object System.Collections.Generic.List[string]\n124:             for ($innerIndex = $index + 1; $innerIndex -lt $lines.Count; $innerIndex++) {\n125:                 $innerLine = $lines[$innerIndex]\n126:                 if ([string]::IsNullOrWhiteSpace($innerLine)) {\n127:                     $collected.Add(\"\")\n128:                     continue\n129:                 }\n130: \n131:                 $innerIndent = ($innerLine.Length - $innerLine.TrimStart().Length)\n132:                 if ($innerIndent -le $baseIndent) {\n133:                     break\n134:                 }\n135: \n136:                 $trimCount = [Math]::Min($innerLine.Length, $baseIndent + 2)\n137:                 $collected.Add($innerLine.Substring($trimCount))\n138:             }\n139: \n140:             if ($rawValue -eq '>') {\n141:                 return (($collected | ForEach-Object { $_.Trim() } | Where-Object { $_ -ne '' }) -join ' ').Trim()\n142:             }\n143: \n144:             return (($collected -join \"`n\").Trim())\n145:         }\n146: \n147:         if ([string]::IsNullOrWhiteSpace($rawValue)) {\n148:             return \"\"\n149:         }\n150: \n151:         return $rawValue.Trim().Trim('\"').Trim(\"'\")\n152:     }\n153: \n154:     return $null\n155: }\n156: \n157: function Normalize-Text {\n158:     param([string]$Value)\n159: \n160:     if ([string]::IsNullOrWhiteSpace($Value)) {\n161:         return \"\"\n162:     }\n163: \n164:     return (($Value.ToLowerInvariant() -replace '[^\\p{L}\\p{Nd}]+', ' ').Trim())\n165: }\n166: \n167: function Get-TextExcerpt {\n168:     param([string]$Body)\n169: \n170:     if ([string]::IsNullOrWhiteSpace($Body)) {\n171:         return \"\"\n172:     }\n173: \n174:     $paragraphs = @($Body -split \"(\\r?\\n){2,}\" | ForEach-Object { $_.Trim() } | Where-Object { $_ })\n175:     foreach ($paragraph in $paragraphs) {\n176:         if ($paragraph -match '^```') {\n177:             continue\n178:         }\n179: \n180:         $lines = @($paragraph -split \"\\r?\\n\" | ForEach-Object { $_.Trim() } | Where-Object { $_ })\n181:         if (-not $lines -or $lines.Count -eq 0) {\n182:             continue\n183:         }\n184: \n185:         if ($lines[0] -match '^#') {\n186:             if ($lines.Count -gt 1) {\n187:                 $candidate = ($lines[1..($lines.Count - 1)] -join ' ').Trim()\n188:                 if ($candidate) {\n189:                     return ($candidate.Substring(0, [Math]::Min(220, $candidate.Length)))\n190:                 }\n191:             }\n192:             continue\n193:         }\n194: \n195:         $candidate = ($lines -join ' ').Trim()\n196:         if ($candidate) {\n197:             return ($candidate.Substring(0, [Math]::Min(220, $candidate.Length)))\n198:         }\n199:     }\n200: \n201:     $fallback = (($Body -split \"\\r?\\n\" | ForEach-Object { $_.Trim() } | Where-Object { $_ -and ($_ -notmatch '^---$') -and ($_ -notmatch '^#') } | Select-Object -First 6) -join ' ').Trim()\n202:     if (-not $fallback) {\n203:         return \"\"\n204:     }\n205: \n206:     return ($fallback.Substring(0, [Math]::Min(220, $fallback.Length)))\n207: }\n208: \n209: function Get-SkillMetadataFromFile {\n210:     param([string]$SkillFilePath)\n211: \n212:     $raw = Read-Utf8Text -Path $SkillFilePath\n213:     $frontmatter = \"\"\n214:     $body = $raw\n215: \n216:     if ($raw -match \"(?s)\\A---\\r?\\n(.*?)\\r?\\n---\\r?\\n?(.*)\\z\") {\n217:         $frontmatter = $matches[1]\n218:         $body = $matches[2]\n219:     }\n220: \n221:     $name = $null\n222:     $description = $null\n223: \n224:     $name = Get-FrontmatterValue -Frontmatter $frontmatter -Name \"name\"\n225:     $description = Get-FrontmatterValue -Frontmatter $frontmatter -Name \"description\"\n226: \n227:     if (-not $name) {\n228:         $name = Split-Path -Leaf (Split-Path -Parent $SkillFilePath)\n229:     }\n230:     if (-not $description) {\n231:         $description = Get-TextExcerpt -Body $body\n232:     }\n233: \n234:     $bodySummary = Get-TextExcerpt -Body $body\n235:     $skillRootPath = Split-Path -Parent $SkillFilePath\n236: \n237:     return [ordered]@{\n238:         name = [string]$name\n239:         description = [string]$description\n240:         bodySummary = [string]$bodySummary\n241:         skillMdPath = [string]$SkillFilePath\n242:         skillRootPath = [string]$skillRootPath\n243:     }\n244: }\n245: \n246: function Get-SkillFilesFromPath {\n247:     param([string]$TargetPath)\n248: \n249:     if (-not (Test-Path -LiteralPath $TargetPath)) {\n250:         Write-SkillLibraryError \"Target path '$TargetPath' does not exist.\"\n251:     }\n252: \n253:     $item = Get-Item -LiteralPath $TargetPath\n254:     if ($item.PSIsContainer) {\n255:         $files = @(\n256:             Get-ChildItem -LiteralPath $TargetPath -Recurse -File |\n257:                 Where-Object { $_.Name -ieq 'SKILL.md' } |\n258:                 Select-Object -ExpandProperty FullName\n259:         )\n260:         return @($files | Sort-Object -Unique)\n261:     }\n262: \n263:     if ($item.Name -ine \"SKILL.md\") {\n264:         Write-SkillLibraryError \"File path '$TargetPath' is not a SKILL.md file.\"\n265:     }\n266: \n267:     return @($item.FullName)\n268: }\n269: \n270: function Initialize-RegistryIfNeeded {\n271:     $entries = @(Get-RegistryEntries)\n272:     if ($entries.Count -gt 0) {\n273:         return $entries\n274:     }\n275: \n276:     $defaultSource = Get-DefaultSourceRoot\n277:     $skillFiles = @(Get-SkillFilesFromPath -TargetPath $defaultSource)\n278:     if ($skillFiles.Count -eq 0) {\n279:         Save-RegistryEntries -Entries @()\n280:         return @()\n\n(Showing lines 1-280 of 484. Use offset=281 to continue.)\n</content>","metadata":{"preview":"[CmdletBinding()]\nparam(\n    [Parameter(ValueFromRemainingArguments = $true)]\n    [string[]]$CommandArgs\n)\n\nSet-StrictMode -Version Latest\n$ErrorActionPreference = \"Stop\"\n[Console]::InputEncoding = [System.Text.UTF8Encoding]::new($false)\n[Console]::OutputEncoding = [System.Text.UTF8Encoding]::new($false)\n$OutputEncoding = [Console]::OutputEncoding\n\n$script:PackageRoot = Split-Path -Parent $PSScriptRoot\n$script:RegistryPath = Join-Path $script:PackageRoot \"registry.json\"\n$script:ConfigPath = Join-Path $script:PackageRoot \"cli.package.json\"\n$script:Utf8NoBom = [System.Text.UTF8Encoding]::new($false)\n$script:Utf8WithBom = [System.Text.UTF8Encoding]::new($true)\n\nfunction Write-SkillLibraryError {\n    param([string]$Message)","truncated":true,"loaded":[]},"title":"agent_workspace\\capability-library\\mycli\\skill-library\\scripts\\skill-library.ps1","time":{"start":1777014305246,"end":1777014305307}},"id":"prt_dbe4e71d80011QVdOPJUdjBHHB","sessionID":"ses_241d9f7b3ffeMqi0Lc2w61CcA3","messageID":"msg_dbe4e5123001D1vOZ2oqeLnjdW"}}
{"type":"tool_use","timestamp":1777014305326,"sessionID":"ses_241d9f7b3ffeMqi0Lc2w61CcA3","part":{"type":"tool","tool":"read","callID":"call_UkkL3SefxStU5ZqSi4kU3gDy","state":{"status":"completed","input":{"filePath":"D:\\agent_workspace\\capability-library\\skill-library\\project-skill-manager\\scripts\\get_project_info.py","limit":160,"offset":1},"output":"<path>D:\\agent_workspace\\capability-library\\skill-library\\project-skill-manager\\scripts\\get_project_info.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: # -*- coding: utf-8 -*-\n3: import os\n4: import yaml\n5: from typing import List, Dict, Optional\n6: \n7: PROJECTS_ROOT = r\"D:\\agent_workspace\\projects\"\n8: \n9: def get_project_info(status: Optional[str] = None) -> List[Dict]:\n10:     projects = []\n11:     for dirpath, dirnames, filenames in os.walk(PROJECTS_ROOT):\n12:         if \"README.md\" in filenames:\n13:             readme_path = os.path.join(dirpath, \"README.md\")\n14:             try:\n15:                 with open(readme_path, \"r\", encoding=\"utf-8\") as f:\n16:                     content = f.read().strip()\n17: \n18:                 if content.startswith(\"---\"):\n19:                     parts = content.split(\"---\", 2)\n20:                     if len(parts) >= 3:\n21:                         yaml_part = parts[1].strip()\n22:                         meta = yaml.safe_load(yaml_part)\n23:                         if isinstance(meta, dict):\n24:                             item = {\n25:                                 \"name\": meta.get(\"name\", os.path.basename(dirpath)),\n26:                                 \"status\": meta.get(\"status\", \"unknown\"),\n27:                                 \"description\": meta.get(\"description\", \"\"),\n28:                                 \"path\": dirpath\n29:                             }\n30:                             projects.append(item)\n31:             except Exception:\n32:                 pass\n33: \n34:     if status:\n35:         projects = [p for p in projects if p.get(\"status\") == status]\n36:     return projects\n37: \n38: if __name__ == \"__main__\":\n39:     import sys, json\n40:     status_arg = sys.argv[1] if len(sys.argv) > 1 else None\n41:     print(json.dumps(get_project_info(status_arg), ensure_ascii=False, indent=2))\n\n(End of file - total 41 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\nimport os\nimport yaml\nfrom typing import List, Dict, Optional\n\nPROJECTS_ROOT = r\"D:\\agent_workspace\\projects\"\n\ndef get_project_info(status: Optional[str] = None) -> List[Dict]:\n    projects = []\n    for dirpath, dirnames, filenames in os.walk(PROJECTS_ROOT):\n        if \"README.md\" in filenames:\n            readme_path = os.path.join(dirpath, \"README.md\")\n            try:\n                with open(readme_path, \"r\", encoding=\"utf-8\") as f:\n                    content = f.read().strip()\n\n                if content.startswith(\"---\"):\n                    parts = content.split(\"---\", 2)\n                    if len(parts) >= 3:","truncated":false,"loaded":[]},"title":"agent_workspace\\capability-library\\skill-library\\project-skill-manager\\scripts\\get_project_info.py","time":{"start":1777014305258,"end":1777014305325}},"id":"prt_dbe4e71de0028snc5JJvb5sJX8","sessionID":"ses_241d9f7b3ffeMqi0Lc2w61CcA3","messageID":"msg_dbe4e5123001D1vOZ2oqeLnjdW"}}
{"type":"tool_use","timestamp":1777014305693,"sessionID":"ses_241d9f7b3ffeMqi0Lc2w61CcA3","part":{"type":"tool","tool":"read","callID":"call_VYzQIq5msfucaX3ImqMO6LzV","state":{"status":"completed","input":{"filePath":"D:\\agent_workspace\\capability-library\\agent-system-rules\\agent-workflow\\README.md","limit":260,"offset":1482},"output":"<path>D:\\agent_workspace\\capability-library\\agent-system-rules\\agent-workflow\\README.md</path>\n<type>file</type>\n<content>\n1482: ## 22. Workflow Project 模版目录\n1483: \n1484: 为了支持“先定义一个 `workflow.json`，再通过脚手架生成完整工程骨架”的开发模式，建议为每个 Workflow 提供标准化项目目录。\n1485: \n1486: 目标：\n1487: \n1488: - 只维护一份 Workflow 定义文件\n1489: - 脚手架根据定义自动生成节点目录\n1490: - 每个节点有自己独立的实现和资源空间\n1491: - 便于单节点调试、测试、替换和版本管理\n1492: \n1493: ### 22.1 推荐目录结构\n1494: \n1495: ```text\n1496: my-workflow/\n1497:   workflow.json\n1498:   README.md\n1499: \n1500:   .generated/\n1501:     manifest.json\n1502:     graph.json\n1503:     scaffold.lock.json\n1504: \n1505:   context/\n1506:     inputs.schema.json\n1507:     context.schema.json\n1508:     outputs.schema.json\n1509: \n1510:   steps/\n1511:     01_wait_user_message/\n1512:       step.json\n1513:       README.md\n1514:       prompts/\n1515:       scripts/\n1516:       fixtures/\n1517:         inputs/\n1518:         outputs/\n1519:       tests/\n1520: \n1521:     02_analyze_message/\n1522:       step.json\n1523:       README.md\n1524:       prompts/\n1525:         system.md\n1526:         user.md\n1527:       scripts/\n1528:       fixtures/\n1529:         inputs/\n1530:         outputs/\n1531:       tests/\n1532: \n1533:     03_execute_action/\n1534:       step.json\n1535:       README.md\n1536:       prompts/\n1537:       scripts/\n1538:         main.py\n1539:       fixtures/\n1540:         inputs/\n1541:         outputs/\n1542:       tests/\n1543: \n1544:     04_human_review/\n1545:       step.json\n1546:       README.md\n1547:       prompts/\n1548:       scripts/\n1549:       fixtures/\n1550:         inputs/\n1551:         outputs/\n1552:       tests/\n1553: \n1554:   shared/\n1555:     prompts/\n1556:     scripts/\n1557:     libs/\n1558:     templates/\n1559: \n1560:   runtime/\n1561:     configs/\n1562:     hooks/\n1563: \n1564:   var/\n1565:     artifacts/\n1566:     debug/\n1567:     logs/\n1568:     cache/\n1569: ```\n1570: \n1571: ### 22.2 各目录职责\n1572: \n1573: #### `workflow.json`\n1574: \n1575: Workflow 主定义文件，是脚手架的输入源。\n1576: \n1577: 建议包含：\n1578: \n1579: - Workflow 基本信息\n1580: - 全局输入输出定义\n1581: - 上下文定义\n1582: - 节点清单\n1583: - 节点依赖与跳转关系\n1584: - 审核配置\n1585: - 运行配置\n1586: \n1587: #### `.generated/`\n1588: \n1589: 脚手架自动生成的辅助文件，不建议手工维护。\n1590: \n1591: 推荐内容：\n1592: \n1593: - `manifest.json`\n1594:   记录生成时间、脚手架版本、节点清单、目录映射\n1595: - `graph.json`\n1596:   将 `workflow.json` 解析后的图结构快照写入此处\n1597: - `scaffold.lock.json`\n1598:   用于记录已生成节点、模板版本、保留文件等信息\n1599: \n1600: #### `context/`\n1601: \n1602: 放全局上下文和输入输出 schema。\n1603: \n1604: 建议包含：\n1605: \n1606: - `inputs.schema.json`\n1607: - `context.schema.json`\n1608: - `outputs.schema.json`\n1609: \n1610: #### `steps/`\n1611: \n1612: 每个节点一个子目录，是整个项目最重要的实现区。\n1613: \n1614: 目录名建议格式：\n1615: \n1616: - `{order}_{step_id}`\n1617: \n1618: 例如：\n1619: \n1620: - `01_wait_user_message`\n1621: - `02_analyze_message`\n1622: - `03_execute_action`\n1623: \n1624: 这样有两个好处：\n1625: \n1626: - 人看目录时有顺序感\n1627: - 允许后续在不改变 `step_id` 的情况下做展示排序\n1628: \n1629: #### `shared/`\n1630: \n1631: 放可复用资源，避免每个节点都复制一份。\n1632: \n1633: 例如：\n1634: \n1635: - 公共 prompt 模板\n1636: - 公共脚本函数\n1637: - 公共 SDK 封装\n1638: - 公共输出模板\n1639: \n1640: #### `runtime/`\n1641: \n1642: 放运行时相关配置。\n1643: \n1644: 例如：\n1645: \n1646: - runtime config\n1647: - hooks\n1648: - 节点前后置处理\n1649: - 审核适配器配置\n1650: \n1651: #### `var/`\n1652: \n1653: 运行产物目录。\n1654: \n1655: 建议默认不提交核心运行产物，但保留目录结构。\n1656: \n1657: 例如：\n1658: \n1659: - `artifacts/`\n1660: - `debug/`\n1661: - `logs/`\n1662: - `cache/`\n1663: \n1664: ### 22.3 单节点目录结构\n1665: \n1666: 建议每个 `steps/{order}_{step_id}/` 目录统一生成以下内容：\n1667: \n1668: ```text\n1669: steps/\n1670:   02_analyze_message/\n1671:     step.json\n1672:     README.md\n1673:     prompts/\n1674:       system.md\n1675:       user.md\n1676:     scripts/\n1677:       main.py\n1678:     fixtures/\n1679:       inputs/\n1680:         params.json\n1681:       outputs/\n1682:         result.json\n1683:       event.json\n1684:     tests/\n1685:       test_step.py\n1686: ```\n1687: \n1688: 字段含义：\n1689: \n1690: - `step.json`\n1691:   当前节点的局部定义\n1692: - `README.md`\n1693:   当前节点职责、输入输出、调试说明\n1694: - `prompts/`\n1695:   agent 节点或审核节点使用的 prompt\n1696: - `scripts/`\n1697:   command/script 节点对应脚本\n1698: - `fixtures/`\n1699:   调试和测试用样例输入输出目录\n1700: - `tests/`\n1701:   当前节点的独立测试\n1702: \n1703: ### 22.4 `workflow.json` 与 `step.json` 的关系\n1704: \n1705: 建议采用：\n1706: \n1707: - `workflow.json` 为单一事实来源\n1708: - 脚手架从 `workflow.json` 生成每个节点的 `step.json`\n1709: \n1710: 也就是说：\n1711: \n1712: - `workflow.json` 是总定义\n1713: - `steps/*/step.json` 是拆分视图和节点本地配置文件\n1714: \n1715: 推荐规则：\n1716: \n1717: - 可由脚手架覆盖的字段由 `workflow.json` 管理\n1718: - 节点目录内的实现文件由开发者维护\n1719: - 若允许局部扩展，可在 `step.json` 中增加 `local_config` 字段，但不建议覆盖主图结构\n1720: \n1721: ### 22.5 不同节点类型的推荐子文件\n1722: \n1723: #### `agent` 节点\n1724: \n1725: 建议生成：\n1726: \n1727: - `prompts/system.md`\n1728: - `prompts/user.md`\n1729: - `fixtures/inputs/params.json`\n1730: - `fixtures/outputs/result.json`\n1731: - `README.md`\n1732: \n1733: 可选：\n1734: \n1735: - `scripts/postprocess.py`\n1736: - `scripts/validate_output.py`\n1737: \n1738: #### `script` 节点\n1739: \n1740: 建议生成：\n1741: \n\n(Showing lines 1482-1741 of 2981. Use offset=1742 to continue.)\n</content>","metadata":{"preview":"## 22. Workflow Project 模版目录\n\n为了支持“先定义一个 `workflow.json`，再通过脚手架生成完整工程骨架”的开发模式，建议为每个 Workflow 提供标准化项目目录。\n\n目标：\n\n- 只维护一份 Workflow 定义文件\n- 脚手架根据定义自动生成节点目录\n- 每个节点有自己独立的实现和资源空间\n- 便于单节点调试、测试、替换和版本管理\n\n### 22.1 推荐目录结构\n\n```text\nmy-workflow/\n  workflow.json\n  README.md\n\n  .generated/\n    manifest.json","truncated":true,"loaded":[]},"title":"agent_workspace\\capability-library\\agent-system-rules\\agent-workflow\\README.md","time":{"start":1777014305655,"end":1777014305688}},"id":"prt_dbe4e71eb001XlPaHz3gT12YWd","sessionID":"ses_241d9f7b3ffeMqi0Lc2w61CcA3","messageID":"msg_dbe4e5123001D1vOZ2oqeLnjdW"}}
