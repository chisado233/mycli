:\n+                result.append(item)\n+    return result\n+\n+\n+def cmd_update_status(args: argparse.Namespace) -> int:\n+    project_file = resolve_project_file(args, args.key)\n+    project = read_json(project_file)\n+    status = project.setdefault(\"status\", {})\n+    current = project.setdefault(\"current\", {})\n+    for field in [\"registration\", \"lifecycle\", \"phase\", \"activity\", \"health\", \"delivery\"]:\n+        value = getattr(args, field)\n+        if value is not None:\n+            status[field] = value\n+    if args.summary is not None:\n+        status[\"summary\"] = args.summary\n+        current[\"summary\"] = args.summary\n+    if args.updated_by is not None:\n+        status[\"updated_by\"] = args.updated_by\n+    if args.attention is not None:\n+        status[\"attention\"] = split_csv(args.attention)\n+    if args.current_task is not None:\n+        current[\"task_id\"] = args.current_task\n+    if args.current_next_action is not None:\n+        current[\"next_action_id\"] = args.current_next_action\n+    save_project_and_update_registry(project_file, project, registry_path_from_args(args))\n+    print(json.dumps({\"project_id\": project.get(\"metadata\", {}).get(\"id\"), \"status\": project.get(\"status\", {}), \"result\": \"updated\"}, ensure_ascii=False, indent=2))\n+    return 0\n+\n+\n+def next_id(directory: Path, prefix: str) -> str:\n+    max_num = 0\n+    for path in directory.glob(f\"{prefix}-*.json\"):\n+        match = re.match(rf\"{re.escape(prefix)}-(\\d+)\", path.stem)\n+        if match:\n+            max_num = max(max_num, int(match.group(1)))\n+    return f\"{prefix}-{max_num + 1:04d}\"\n+\n+\n+def load_records(directory: Path, prefix: str) -> list[dict[str, Any]]:\n+    records: list[dict[str, Any]] = []\n+    if not directory.exists():\n+        return records\n+    for path in sorted(directory.glob(f\"{prefix}-*.json\")):\n+        try:\n+            records.append(read_json(path))\n+        except Exception as exc:\n+            print(f\"warning: failed to read {path}: {exc}\", file=sys.stderr)\n+    return records\n+\n+\n+def print_records(records: list[dict[str, Any]], as_json: bool) -> None:\n+    if as_json:\n+        print(json.dumps(records, ensure_ascii=False, indent=2))\n+        return\n+    columns = [\"id\", \"title\", \"type\", \"status\", \"priority\", \"owner\"]\n+    widths = {col: len(col) for col in columns}\n+    for record in records:\n+        for col in columns:\n+            widths[col] = max(widths[col], min(36, len(str(record.get(col, \"\")))))\n+    print(\"  \".join(col.ljust(widths[col]) for col in columns))\n+    print(\"  \".join(\"-\" * widths[col] for col in columns))\n+    for record in records:\n+        row = []\n+        for col in columns:\n+            value = str(record.get(col, \"\"))\n+            if len(value) > 36:\n+                value = value[:33] + \"...\"\n+            row.append(value.ljust(widths[col]))\n+        print(\"  \".join(row))\n+\n+\n+def cmd_task_list(args: argparse.Namespace) -> int:\n+    project_file = resolve_project_file(args, args.key)\n+    records = load_records(project_file.parent / \"tasks\", \"task\")\n+    if args.status:\n+        records = [r for r in records if r.get(\"status\") == args.status]\n+    print_records(records, args.json)\n+    return 0\n+\n+\n+def cmd_task_add(args: argparse.Namespace) -> int:\n+    project_file = resolve_project_file(args, args.key)\n+    project = read_json(project_file)\n+    tasks_dir = project_file.parent / \"tasks\"\n+    tasks_dir.mkdir(parents=True, exist_ok=True)\n+    task_id = args.id or next_id(tasks_dir, \"task\")\n+    timestamp = now_iso()\n+    record = {\n+        \"id\": task_id,\n+        \"title\": args.title,\n+        \"type\": args.type,\n+        \"status\": args.status,\n+        \"priority\": args.priority,\n+        \"phase\": args.phase,\n+        \"owner\": args.owner,\n+        \"depends_on\": split_csv(args.depends_on),\n+        \"blocks\": split_csv(args.blocks),\n+        \"tags\": split_csv(args.tag),\n+        \"acceptance_criteria\": split_csv(args.acceptance),\n+        \"created_at\": timestamp,\n+        \"updated_at\": timestamp,\n+    }\n+    write_json(tasks_dir / f\"{task_id}.json\", record)\n+    if args.set_current:\n+        project.setdefault(\"current\", {})[\"task_id\"] = task_id\n+        project.setdefault(\"current\", {})[\"summary\"] = args.title\n+    save_project_and_update_registry(project_file, project, registry_path_from_args(args))\n+    print(json.dumps(record, ensure_ascii=False, indent=2))\n+    return 0\n+\n+\n+def cmd_task_update(args: argparse.Namespace) -> int:\n+    project_file = resolve_project_file(args, args.key)\n+    project = read_json(project_file)\n+    path = project_file.parent / \"tasks\" / f\"{args.task_id}.json\"\n+    if not path.exists():\n+        raise SystemExit(f\"Task not found: {args.task_id}\")\n+    record = read_json(path)\n+    for field in [\"title\", \"type\", \"status\", \"priority\", \"phase\", \"owner\"]:\n+        value = getattr(args, field)\n+        if value is not None:\n+            record[field] = value\n+    if args.tag is not None:\n+        record[\"tags\"] = split_csv(args.tag)\n+    if args.acceptance is not None:\n+        record[\"acceptance_criteria\"] = split_csv(args.acceptance)\n+    record[\"updated_at\"] = now_iso()\n+    write_json(path, record)\n+    if args.set_current:\n+        project.setdefault(\"current\", {})[\"task_id\"] = args.task_id\n+        project.setdefault(\"current\", {})[\"summary\"] = record.get(\"title\", \"\")\n+    save_project_and_update_registry(project_file, project, registry_path_from_args(args))\n+    print(json.dumps(record, ensure_ascii=False, indent=2))\n+    return 0\n+\n+\n+def cmd_next_list(args: argparse.Namespace) -> int:\n+    project_file = resolve_project_file(args, args.key)\n+    records = load_records(project_file.parent / \"next-actions\", \"next\")\n+    if args.stat