{"type":"tool_use","timestamp":1777287432549,"sessionID":"ses_2316acf38ffernm7DeFvFqL4NM","part":{"type":"tool","tool":"read","callID":"call_XZO5UlFCBf9IKqwWIQmTyYiV","state":{"status":"completed","input":{"filePath":"D:\\agent_workspace\\projects\\github-hot-repos-report\\scripts\\fetch_trending_no_token.py","limit":300,"offset":1},"output":"<path>D:\\agent_workspace\\projects\\github-hot-repos-report\\scripts\\fetch_trending_no_token.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"Fetch public GitHub Trending candidates without authentication.\n3: \n4: This script intentionally uses only Python standard library modules and public\n5: GitHub Trending pages. It is a lightweight helper that generates candidate\n6: JSON/Markdown output for later human review.\n7: \"\"\"\n8: \n9: from __future__ import annotations\n10: \n11: import argparse\n12: import datetime as dt\n13: import html\n14: import json\n15: import pathlib\n16: import re\n17: import sys\n18: import urllib.error\n19: import urllib.parse\n20: import urllib.request\n21: \n22: \n23: SCRIPT_DIR = pathlib.Path(__file__).resolve().parent\n24: PROJECT_ROOT = SCRIPT_DIR.parent\n25: DEFAULT_USER_AGENT = (\n26:     \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) \"\n27:     \"AppleWebKit/537.36 (KHTML, like Gecko) \"\n28:     \"Chrome/124.0 Safari/537.36\"\n29: )\n30: \n31: \n32: def build_url(since: str, language: str | None, spoken_language: str | None) -> str:\n33:     params: dict[str, str] = {\"since\": since}\n34:     if spoken_language:\n35:         params[\"spoken_language_code\"] = spoken_language\n36: \n37:     base = \"https://github.com/trending\"\n38:     if language:\n39:         base = f\"{base}/{urllib.parse.quote(language)}\"\n40:     return f\"{base}?{urllib.parse.urlencode(params)}\"\n41: \n42: \n43: def fetch_html(url: str, timeout: int) -> str:\n44:     request = urllib.request.Request(\n45:         url,\n46:         headers={\n47:             \"User-Agent\": DEFAULT_USER_AGENT,\n48:             \"Accept\": \"text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8\",\n49:             \"Accept-Language\": \"en-US,en;q=0.9\",\n50:         },\n51:     )\n52:     with urllib.request.urlopen(request, timeout=timeout) as response:\n53:         charset = response.headers.get_content_charset() or \"utf-8\"\n54:         return response.read().decode(charset, errors=\"replace\")\n55: \n56: \n57: def _clean_text(raw: str | None) -> str | None:\n58:     if raw is None:\n59:         return None\n60:     text = html.unescape(raw)\n61:     text = re.sub(r\"<[^>]+>\", \" \", text)\n62:     text = text.replace(\"\\r\", \" \").replace(\"\\n\", \" \")\n63:     text = re.sub(r\"\\s+\", \" \", text).strip()\n64:     return text or None\n65: \n66: \n67: def parse_trending_page(page_html: str, source_url: str, limit: int) -> list[dict[str, str | None]]:\n68:     articles = re.findall(\n69:         r\"<article\\b[^>]*class=\\\"[^\\\"]*Box-row[^\\\"]*\\\"[^>]*>(.*?)</article>\",\n70:         page_html,\n71:         flags=re.IGNORECASE | re.DOTALL,\n72:     )\n73: \n74:     results: list[dict[str, str | None]] = []\n75:     for block in articles:\n76:         repo_match = re.search(\n77:             r\"<h2[^>]*>.*?<a[^>]*href=\\\"/([^\\\"]+)\\\"\",\n78:             block,\n79:             flags=re.IGNORECASE | re.DOTALL,\n80:         )\n81:         if not repo_match:\n82:             continue\n83: \n84:         repo_name = repo_match.group(1).strip().strip(\"/\")\n85:         url = f\"https://github.com/{repo_name}\"\n86: \n87:         desc_match = re.search(r\"<p[^>]*>(.*?)</p>\", block, flags=re.IGNORECASE | re.DOTALL)\n88:         lang_match = re.search(\n89:             r\"itemprop=\\\"programmingLanguage\\\"[^>]*>(.*?)</span>\",\n90:             block,\n91:             flags=re.IGNORECASE | re.DOTALL,\n92:         )\n93:         stars_match = re.search(\n94:             r\"href=\\\"/[^\\\"]+/stargazers\\\"[^>]*>\\s*([^<]+?)\\s*</a>\",\n95:             block,\n96:             flags=re.IGNORECASE | re.DOTALL,\n97:         )\n98:         today_match = re.search(\n99:             r\"<span[^>]*>\\s*([^<]*stars today[^<]*)\\s*</span>\",\n100:             block,\n101:             flags=re.IGNORECASE | re.DOTALL,\n102:         )\n103: \n104:         results.append(\n105:             {\n106:                 \"repo\": repo_name,\n107:                 \"url\": url,\n108:                 \"description\": _clean_text(desc_match.group(1) if desc_match else None),\n109:                 \"language\": _clean_text(lang_match.group(1) if lang_match else None),\n110:                 \"stars\": _clean_text(stars_match.group(1) if stars_match else None),\n111:                 \"stars_today\": _clean_text(today_match.group(1) if today_match else None),\n112:                 \"source\": source_url,\n113:             }\n114:         )\n115: \n116:         if len(results) >= limit:\n117:             break\n118: \n119:     return results\n120: \n121: \n122: def to_markdown(items: list[dict[str, str | None]], source_url: str, since: str) -> str:\n123:     today = dt.date.today().isoformat()\n124:     lines = [\n125:         \"# GitHub Trending 候选列表\",\n126:         \"\",\n127:         f\"- 生成日期：{today}\",\n128:         f\"- 来源：{source_url}\",\n129:         f\"- 范围：{since}\",\n130:         \"- 采集方式：无 token 公开页面抓取（待人工复核）\",\n131:         \"\",\n132:         \"## 候选仓库\",\n133:         \"\",\n134:     ]\n135: \n136:     for index, item in enumerate(items, start=1):\n137:         lines.extend(\n138:             [\n139:                 f\"### {index}. {item['repo']}\",\n140:                 \"\",\n141:                 f\"- URL：{item['url']}\",\n142:                 f\"- 主要语言：{item.get('language') or '未识别'}\",\n143:                 f\"- Stars：{item.get('stars') or '未识别'}\",\n144:                 f\"- 当日增量：{item.get('stars_today') or '未识别'}\",\n145:                 f\"- 描述：{item.get('description') or '无'}\",\n146:                 f\"- 备注：需人工复核页面内容后再写入正式报告。\",\n147:                 \"\",\n148:             ]\n149:         )\n150: \n151:     return \"\\n\".join(lines)\n152: \n153: \n154: def ensure_parent(path: pathlib.Path) -> None:\n155:     path.parent.mkdir(parents=True, exist_ok=True)\n156: \n157: \n158: def write_log(log_path: pathlib.Path, status: str, message: str) -> None:\n159:     ensure_parent(log_path)\n160:     timestamp = dt.datetime.now().isoformat(timespec=\"seconds\")\n161:     with log_path.open(\"a\", encoding=\"utf-8\") as fh:\n162:         fh.write(f\"[{timestamp}] {status}: {message}\\n\")\n163: \n164: \n165: def build_manual_fallback_message(url: str) -> str:\n166:     return (\n167:         \"未能稳定解析 GitHub Trending 公开页面。\\n\"\n168:         f\"请人工打开：{url}\\n\"\n169:         \"按 reports/template.md 手工整理候选仓库，并在正式报告中标明：\\n\"\n170:         \"- 本次为人工整理或脚本失败后人工兜底；\\n\"\n171:         \"- 未使用 token、Cookie、登录态；\\n\"\n172:         \"- 如页面结构变化，请在 runbook 中记录异常现象。\"\n173:     )\n174: \n175: \n176: def parse_args(argv: list[str]) -> argparse.Namespace:\n177:     parser = argparse.ArgumentParser(\n178:         description=\"Fetch GitHub Trending candidates without token or login.\",\n179:     )\n180:     parser.add_argument(\"--since\", choices=[\"daily\", \"weekly\", \"monthly\"], default=\"daily\")\n181:     parser.add_argument(\"--language\", help=\"Optional GitHub Trending language path segment.\")\n182:     parser.add_argument(\n183:         \"--spoken-language\",\n184:         help=\"Optional spoken_language_code query value, for example en or zh.\",\n185:     )\n186:     parser.add_argument(\"--limit\", type=int, default=10, help=\"Max repos to keep in output.\")\n187:     parser.add_argument(\"--timeout\", type=int, default=20, help=\"Network timeout in seconds.\")\n188:     parser.add_argument(\"--json-out\", help=\"Optional path to write JSON candidate output.\")\n189:     parser.add_argument(\"--md-out\", help=\"Optional path to write Markdown candidate output.\")\n190:     parser.add_argument(\n191:         \"--log-file\",\n192:         help=\"Optional append-only log path. Suggested: state/logs/trending-fetch.log\",\n193:     )\n194:     parser.add_argument(\n195:         \"--print-json\",\n196:         action=\"store_true\",\n197:         help=\"Print JSON candidates to stdout after a successful fetch.\",\n198:     )\n199:     return parser.parse_args(argv)\n200: \n201: \n202: def main(argv: list[str]) -> int:\n203:     args = parse_args(argv)\n204:     source_url = build_url(args.since, args.language, args.spoken_language)\n205: \n206:     try:\n207:         page_html = fetch_html(source_url, timeout=args.timeout)\n208:         items = parse_trending_page(page_html, source_url=source_url, limit=args.limit)\n209:         if not items:\n210:             raise RuntimeError(build_manual_fallback_message(source_url))\n211:     except urllib.error.HTTPError as exc:\n212:         message = (\n213:             f\"访问 GitHub Trending 失败，HTTP {exc.code}。\\n\"\n214:             f\"目标地址：{source_url}\\n\"\n215:             f\"{build_manual_fallback_message(source_url)}\"\n216:         )\n217:         if args.log_file:\n218:             write_log(pathlib.Path(args.log_file), \"ERROR\", f\"HTTP {exc.code} for {source_url}\")\n219:         print(message, file=sys.stderr)\n220:         return 2\n221:     except urllib.error.URLError as exc:\n222:         message = (\n223:             f\"访问 GitHub Trending 失败：{exc.reason}\\n\"\n224:             f\"目标地址：{source_url}\\n\"\n225:             f\"{build_manual_fallback_message(source_url)}\"\n226:         )\n227:         if args.log_file:\n228:             write_log(pathlib.Path(args.log_file), \"ERROR\", f\"URL error for {source_url}: {exc.reason}\")\n229:         print(message, file=sys.stderr)\n230:         return 2\n231:     except Exception as exc:\n232:         if args.log_file:\n233:             write_log(pathlib.Path(args.log_file), \"ERROR\", f\"Parse/runtime failure for {source_url}: {exc}\")\n234:         print(str(exc), file=sys.stderr)\n235:         return 3\n236: \n237:     payload = {\n238:         \"generated_at\": dt.datetime.now().isoformat(timespec=\"seconds\"),\n239:         \"source\": source_url,\n240:         \"since\": args.since,\n241:         \"language\": args.language,\n242:         \"spoken_language\": args.spoken_language,\n243:         \"count\": len(items),\n244:         \"items\": items,\n245:         \"note\": \"Candidates only. Human review required before final report.\",\n246:     }\n247: \n248:     if args.json_out:\n249:         json_path = pathlib.Path(args.json_out)\n250:         ensure_parent(json_path)\n251:         json_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding=\"utf-8\")\n252: \n253:     if args.md_out:\n254:         md_path = pathlib.Path(args.md_out)\n255:         ensure_parent(md_path)\n256:         md_path.write_text(to_markdown(items, source_url=source_url, since=args.since), encoding=\"utf-8\")\n257: \n258:     if args.log_file:\n259:         write_log(pathlib.Path(args.log_file), \"OK\", f\"Fetched {len(items)} repos from {source_url}\")\n260: \n261:     if args.print_json or (not args.json_out and not args.md_out):\n262:         print(json.dumps(payload, ensure_ascii=False, indent=2))\n263:     else:\n264:         summary = f\"Fetched {len(items)} repos from {source_url}\"\n265:         print(summary)\n266: \n267:     return 0\n268: \n269: \n270: if __name__ == \"__main__\":\n271:     raise SystemExit(main(sys.argv[1:]))\n\n(End of file - total 271 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Fetch public GitHub Trending candidates without authentication.\n\nThis script intentionally uses only Python standard library modules and public\nGitHub Trending pages. It is a lightweight helper that generates candidate\nJSON/Markdown output for later human review.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport datetime as dt\nimport html\nimport json\nimport pathlib\nimport re\nimport sys\nimport urllib.error\nimport urllib.parse\nimport urllib.request","truncated":false,"loaded":[]},"title":"agent_workspace\\projects\\github-hot-repos-report\\scripts\\fetch_trending_no_token.py","time":{"start":1777287432518,"end":1777287432548}},"id":"prt_dce960942002hrsaxWz0S6V2rI","sessionID":"ses_2316acf38ffernm7DeFvFqL4NM","messageID":"msg_dce95e8dc001pyEVBESNeTSsSc"}}
