{
  "version": 1,
  "default_agent": "opencode/private-assistant",
  "sync": {
    "auto_sync": true,
    "sync_on_agent_list": true,
    "sync_on_agent_create": true,
    "providers": [
      "opencode"
    ]
  },
  "providers": {
    "codex": {
      "enabled": true,
      "kind": "local_cli",
      "display_name": "Codex CLI",
      "binary": "codex",
      "proxy": {
        "mode": "auto",
        "script": "D:\\agent_workspace\\capability-library\\mycli\\clash\\scripts\\clash-cli.ps1",
        "auto_state_file": "D:\\agent_workspace\\capability-library\\mycli\\clash\\state\\auto-state.json",
        "config_file": "C:\\Users\\38188\\.config\\clash\\config.yaml",
        "auto_start_if_needed": true
      },
      "environment": {
        "NO_PROXY": "127.0.0.1,localhost"
      },
      "discovery": {
        "type": "static"
      },
      "capabilities": {
        "supports_agent_create": false,
        "supports_session_name": false,
        "supports_continue_last": true,
        "supports_session_resume": true,
        "supports_session_fork": true,
        "supports_model_override": true,
        "supports_workdir": true
      },
      "run_mapping": {
        "new_session": {
          "command": [
            "codex",
            "exec"
          ],
          "argument_map": {
            "prompt": {
              "type": "positional_prompt"
            },
            "model": {
              "flag": "--model"
            },
            "cwd": {
              "flag": "--cd"
            }
          }
        },
        "continue_last": {
          "command": [
            "codex",
            "resume",
            "--last"
          ],
          "argument_map": {
            "prompt": {
              "type": "positional_prompt"
            },
            "model": {
              "flag": "--model"
            },
            "cwd": {
              "flag": "--cd"
            }
          }
        },
        "resume_session": {
          "command": [
            "codex",
            "resume"
          ],
          "argument_map": {
            "session": {
              "type": "positional_session"
            },
            "prompt": {
              "type": "positional_prompt"
            },
            "model": {
              "flag": "--model"
            },
            "cwd": {
              "flag": "--cd"
            }
          }
        },
        "fork_session": {
          "command": [
            "codex",
            "fork"
          ],
          "argument_map": {
            "session": {
              "type": "positional_session"
            },
            "prompt": {
              "type": "positional_prompt"
            },
            "model": {
              "flag": "--model"
            },
            "cwd": {
              "flag": "--cd"
            }
          }
        }
      },
      "session_name_strategy": {
        "type": "agent_cli_local_metadata",
        "field": "session_name"
      },
      "agents": {
        "default": {
          "mapped_name": "codex/default",
          "display_name": "codex/default",
          "upstream_agent_name": "default",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "codex",
            "general"
          ]
        }
      }
    },
    "opencode": {
      "enabled": true,
      "kind": "local_cli",
      "display_name": "OpenCode CLI",
      "binary": "opencode",
      "discovery": {
        "type": "command",
        "command": [
          "opencode",
          "agent",
          "list"
        ]
      },
      "capabilities": {
        "supports_agent_create": true,
        "supports_session_name": true,
        "supports_continue_last": true,
        "supports_session_resume": true,
        "supports_session_fork": true,
        "supports_model_override": true,
        "supports_workdir": true
      },
      "run_mapping": {
        "new_session": {
          "command": [
            "opencode",
            "run"
          ],
          "argument_map": {
            "prompt": {
              "type": "positional_prompt"
            },
            "agent": {
              "flag": "--agent",
              "value_from": "upstream_agent_name"
            },
            "model": {
              "flag": "--model"
            },
            "session_name": {
              "flag": "--title"
            },
            "cwd": {
              "flag": "--dir"
            }
          }
        },
        "continue_last": {
          "command": [
            "opencode",
            "run",
            "--continue"
          ],
          "argument_map": {
            "prompt": {
              "type": "positional_prompt"
            },
            "agent": {
              "flag": "--agent",
              "value_from": "upstream_agent_name"
            },
            "model": {
              "flag": "--model"
            },
            "cwd": {
              "flag": "--dir"
            }
          }
        },
        "resume_session": {
          "command": [
            "opencode",
            "run"
          ],
          "argument_map": {
            "prompt": {
              "type": "positional_prompt"
            },
            "session": {
              "flag": "--session"
            },
            "agent": {
              "flag": "--agent",
              "value_from": "upstream_agent_name"
            },
            "model": {
              "flag": "--model"
            },
            "cwd": {
              "flag": "--dir"
            }
          }
        },
        "fork_session": {
          "command": [
            "opencode",
            "run",
            "--fork"
          ],
          "argument_map": {
            "prompt": {
              "type": "positional_prompt"
            },
            "session": {
              "flag": "--session"
            },
            "agent": {
              "flag": "--agent",
              "value_from": "upstream_agent_name"
            },
            "model": {
              "flag": "--model"
            },
            "session_name": {
              "flag": "--title"
            },
            "cwd": {
              "flag": "--dir"
            }
          }
        }
      },
      "create_mapping": {
        "command": [
          "opencode",
          "agent",
          "create"
        ],
        "argument_map": {
          "name": {
            "type": "resolved_into_path_filename"
          },
          "description": {
            "flag": "--description"
          },
          "mode": {
            "flag": "--mode"
          },
          "tools": {
            "flag": "--tools",
            "type": "comma_joined"
          },
          "path": {
            "flag": "--path",
            "type": "derived_agent_directory"
          }
        },
        "post_create": {
          "sync_provider": true
        }
      },
      "session_name_strategy": {
        "type": "provider_flag",
        "flag": "--title"
      },
      "agents": {
        "build": {
          "mapped_name": "opencode/build",
          "display_name": "opencode/build",
          "upstream_agent_name": "build",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "build"
          ]
        },
        "compaction": {
          "mapped_name": "opencode/compaction",
          "display_name": "opencode/compaction",
          "upstream_agent_name": "compaction",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "maintenance"
          ]
        },
        "explore": {
          "mapped_name": "opencode/explore",
          "display_name": "opencode/explore",
          "upstream_agent_name": "explore",
          "mode": "subagent",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "research"
          ]
        },
        "general": {
          "mapped_name": "opencode/general",
          "display_name": "opencode/general",
          "upstream_agent_name": "general",
          "mode": "subagent",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "general"
          ]
        },
        "plan": {
          "mapped_name": "opencode/plan",
          "display_name": "opencode/plan",
          "upstream_agent_name": "plan",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "planning"
          ]
        },
        "summary": {
          "mapped_name": "opencode/summary",
          "display_name": "opencode/summary",
          "upstream_agent_name": "summary",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "summary"
          ]
        },
        "title": {
          "mapped_name": "opencode/title",
          "display_name": "opencode/title",
          "upstream_agent_name": "title",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "naming"
          ]
        },
        "luoli": {
          "mapped_name": "opencode/luoli",
          "display_name": "opencode/洛璃",
          "upstream_agent_name": "洛璃",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "custom"
          ]
        },
        "agent-creator": {
          "mapped_name": "opencode/agent-creator",
          "display_name": "opencode/agent-creator",
          "upstream_agent_name": "agent-creator",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "meta"
          ]
        },
        "novelist": {
          "mapped_name": "opencode/novelist",
          "display_name": "opencode/novelist",
          "upstream_agent_name": "novelist",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "writing"
          ]
        },
        "private-assistant": {
          "mapped_name": "opencode/private-assistant",
          "display_name": "opencode/private-assistant",
          "upstream_agent_name": "private-assistant",
          "mode": "primary",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "assistant"
          ]
        },
        "tool-registrant": {
          "mapped_name": "opencode/tool-registrant",
          "display_name": "opencode/tool-registrant",
          "upstream_agent_name": "tool-registrant",
          "mode": "all",
          "enabled": true,
          "default_model": null,
          "tags": [
            "opencode",
            "tooling"
          ]
        }
      }
    }
  }
}
