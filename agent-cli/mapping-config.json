{
  "version": 1,
  "default_agent": "opencode/private-assistant",
  "sync": {
    "auto_sync": true,
    "sync_on_agent_list": true,
    "sync_on_agent_create": true,
    "providers": [
      "opencode"
    ]
  },
  "providers": {
    "codex": {
      "enabled": true,
      "kind": "local_cli",
      "display_name": "Codex CLI",
      "binary": "C:\\Users\\38188\\AppData\\Roaming\\npm\\codex.ps1",
      "proxy": {
        "mode": "auto",
        "script": "D:\\agent_workspace\\capability-library\\mycli\\clash\\scripts\\clash-cli.ps1",
        "auto_state_file": "D:\\agent_workspace\\capability-library\\mycli\\clash\\state\\auto-state.json",
        "config_file": "C:\\Users\\38188\\.config\\clash\\config.yaml",
        "auto_start_if_needed": true
      },
      "environment": {
        "NO_PROXY": "127.0.0.1,localhost"
      },
      "discovery": {
        "type": "static"
      },
      "capabilities": {
        "supports_agent_create": false,
        "supports_session_name": false,
        "supports_continue_last": true,
        "supports_session_resume": true,
        "supports_session_fork": true,
        "supports_model_override": true,
        "supports_workdir": true
      },
      "session_name_strategy": {
        "type": "agent_cli_local_metadata",
        "field": "session_name"
      },
      "agents": {
        "default": {
          "mapped_name": "codex/default",
          "display_name": "codex/default",
          "upstream_agent_name": "default",
          "mode": "primary",
          "enabled": true
        }
      }
    },
    "claude": {
      "enabled": true,
      "kind": "local_cli",
      "display_name": "Claude Code CLI",
      "binary": "C:\\Users\\38188\\.local\\bin\\claude.exe",
      "environment": {
        "CLAUDE_CODE_GIT_BASH_PATH": "D:\\GIT\\Git\\usr\\bin\\bash.exe"
      },
      "discovery": {
        "type": "command",
        "command": [
          "C:\\Users\\38188\\.local\\bin\\claude.exe",
          "agents"
        ]
      },
      "capabilities": {
        "supports_agent_create": false,
        "supports_session_name": true,
        "supports_continue_last": true,
        "supports_session_resume": true,
        "supports_session_fork": true,
        "supports_model_override": true,
        "supports_workdir": true
      },
      "agents": {
        "default": {
          "mapped_name": "claude/default",
          "display_name": "claude/default",
          "upstream_agent_name": "default",
          "mode": "primary",
          "enabled": true
        }
      }
    },
    "opencode": {
      "enabled": true,
      "kind": "local_cli",
      "display_name": "OpenCode CLI",
      "binary": "C:\\Users\\38188\\AppData\\Roaming\\npm\\opencode.ps1",
      "discovery": {
        "type": "command",
        "command": [
          "C:\\Users\\38188\\AppData\\Roaming\\npm\\opencode.ps1",
          "agent",
          "list"
        ]
      },
      "capabilities": {
        "supports_agent_create": true,
        "supports_session_name": true,
        "supports_continue_last": true,
        "supports_session_resume": true,
        "supports_session_fork": true,
        "supports_model_override": true,
        "supports_workdir": true
      },
      "agent_create": {
        "strategy": "template_write",
        "directory": "C:\\Users\\38188\\.config\\opencode\\agent"
      },
      "session_name_strategy": {
        "type": "provider_flag",
        "flag": "--title"
      },
      "agent_aliases": {
        "洛璃": {
          "mapped_name": "opencode/luoli",
          "display_name": "opencode/洛璃"
        }
      }
    }
  }
}
